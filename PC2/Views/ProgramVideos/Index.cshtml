@model IEnumerable<PC2.Models.ProgramVideo>

@section head {
    <style>
        h2 {
            text-align: center;
        }
        .player {
            display: block;
            margin-left: auto;
            margin-right: auto;
        }
        .video-section {
            margin-bottom: 2rem;
        }
    </style>
}

@{
    ViewData["Title"] = "Program Videos";
}
<div class="d-flex justify-content-center">
    <img src="~/images/program-videos/Filmstrip.webp" alt="Horizontal black and white filmstrip representing PC2's legal video series" width="977" height="279" />
</div>

<div>
    <h1>PC2 Legal Series</h1>
</div>

<div class="divider"></div>

@if (Model != null && Model.Any())
{
    <div id="video-list">
        @foreach (var video in Model)
        {
            <div class="video-section">
                <div class="flex-column justify-content-center">
                    <h1>@video.Title</h1>
                </div>
                <div class="player" id="player-@video.ProgramVideoId"></div>
                @if (!string.IsNullOrEmpty(video.PdfLocation))
                {
                    <div class="row g-4 mt-1">
                        <div class="col-12 col-lg-8">
                            <div class="card h-100 shadow-sm">
                                <div class="card-body d-flex flex-column">
                                    <div class="d-flex align-items-center mb-3 min-width-0">
                                        <i class="bi bi-file-earmark-pdf text-danger me-3 fs-1" aria-hidden="true"></i>
                                        <div class="flex-grow-1">
                                            <h5 class="card-title mb-1 text-primary">@video.PdfName</h5>
                                            <small class="text-muted">PDF Handout</small>
                                        </div>
                                    </div>
                                    <div class="mt-auto">
                                        <a href="@video.PdfLocation"
                                           target="_blank"
                                           class="btn btn-primary text-white w-100 d-flex align-items-center justify-content-center"
                                           aria-label="Download @video.PdfName PDF">
                                            <i class="bi bi-download me-2" aria-hidden="true"></i>
                                            Download PDF
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                <br />
            </div>
        }
    </div>

    <script>
        var tag = document.createElement('script');
        tag.src = "https://www.youtube.com/iframe_api";
        var firstScriptTag = document.getElementsByTagName('script')[0];
        firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);

        var videoIds = [
            @Html.Raw(string.Join(",\n            ", Model.Select(v => $"{{ id: {v.ProgramVideoId}, youtubeId: '{v.YouTubeVideoId}' }}")))
        ];

        function onYouTubeIframeAPIReady() {
            videoIds.forEach(function (video) {
                new YT.Player('player-' + video.id, {
                    height: '390',
                    width: '640',
                    videoId: video.youtubeId,
                    playerVars: {
                        'playsinline': 1
                    }
                });
            });
        }
    </script>
}
else
{
    <p>No videos are currently available.</p>
}
